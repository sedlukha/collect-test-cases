{
  "name": "collect-test-cases",
  "version": "0.3.0",
  "description": "Scan Playwright/Vitest/Jest spec files and generate a single Markdown README per app, with optional screenshot galleries and an i18n plugin.",
  "keywords": [
    "playwright",
    "test",
    "cases",
    "markdown",
    "readme",
    "generator",
    "documentation",
    "monorepo",
    "screenshots",
    "i18n"
  ],
  "license": "MIT",
  "author": "sedlukha",
  "homepage": "https://github.com/sedlukha/collect-test-cases#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sedlukha/collect-test-cases.git"
  },
  "bugs": {
    "url": "https://github.com/sedlukha/collect-test-cases/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugins/i18n": {
      "types": "./dist/plugins/i18n/index.d.ts",
      "default": "./dist/plugins/i18n/index.js"
    }
  },
  "bin": {
    "collect-test-cases": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && node scripts/post-build.js",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "regen-examples": "node scripts/regen-examples.mjs",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@10.27.0"
}
